# App
PORT=3000
NODE_ENV=development

# Database (Prisma / PostgreSQL)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
DATABASE_URL=


# JWT — dual token
JWT_ACCESS_SECRET=change-this-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Object storage — Local: MinIO (docker-compose), Dev/Production: Cloudflare R2
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=

# Mail (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Sentry 
SENTRY_DSN=

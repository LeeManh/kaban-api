// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  CARD_ASSIGNED
  DUE_REMINDER
  COMMENT_MENTION
  BOARD_INVITATION
  CARD_REMOVED
  ATTACHMENT_ADDED
  CARD_MOVED
}

enum EmailFrequency {
  NEVER
  INSTANT
}

enum InviteLinkPermission {
  OPEN
  APPROVAL
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TemplateCategory {
  BUSINESS
  DESIGN
  EDUCATION
  ENGINEERING
  MARKETING
  REMOTE_WORK
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  avatar    String?
  bio       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshToken           RefreshToken[]
  ownedBoards            Board[]                 @relation("BoardOwner")
  boardMembers           BoardMember[]
  comments               Comment[]
  attachments            Attachment[]
  assignedCards          Card[]                  @relation("CardAssignees")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  boardViews             BoardView[]
  boardStars             BoardStar[]
  sentInvites            BoardInvite[]
  createdInviteLinks     BoardInviteLink[]
  joinRequests           BoardJoinRequest[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Board {
  id                  String            @id @default(cuid())
  name                String
  background          String
  ownerId             String            @map("owner_id")
  owner               User              @relation("BoardOwner", fields: [ownerId], references: [id])
  members             BoardMember[]
  lists               List[]
  labels              Label[]
  views               BoardView[]
  stars               BoardStar[]
  invites             BoardInvite[]
  inviteLink          BoardInviteLink?
  createdAt           DateTime          @default(now()) @map("created_at")
  isTemplate          Boolean           @default(false) @map("is_template")
  templateCategory    TemplateCategory? @map("template_category")
  templateDescription String?           @db.Text @map("template_description")

  @@index([isTemplate, templateCategory])
  @@map("boards")
}

model BoardMember {
  boardId   String   @map("board_id")
  userId    String   @map("user_id")
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
  @@index([userId])
  @@map("board_members")
}

model List {
  id        String   @id @default(cuid())
  title     String
  order     Float
  boardId   String   @map("board_id")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([boardId, order])
  @@map("lists")
}

model Card {
  id                    String       @id @default(cuid())
  title                 String
  description           String?      @db.Text
  order                 Float
  priority              CardPriority @default(MEDIUM)
  dueDate               DateTime?    @map("due_date")
  reminderOffsetMinutes Int?         @map("reminder_offset_minutes")
  isDone                Boolean      @default(false) @map("is_done")
  cover                 String?
  version               Int          @default(0)
  listId                String       @map("list_id")
  list                  List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels                Label[]
  comments              Comment[]
  checklists            Checklist[]
  attachments           Attachment[]
  assignees             User[]       @relation("CardAssignees")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  @@index([listId, order])
  @@map("cards")
}

model Checklist {
  id        String          @id @default(cuid())
  title     String
  order     Float
  cardId    String          @map("card_id")
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([cardId, order])
  @@map("checklists")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  content     String
  isDone      Boolean   @default(false) @map("is_done")
  order       Float
  checklistId String    @map("checklist_id")
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, order])
  @@map("checklist_items")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  cardId    String   @map("card_id")
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cardId, createdAt])
  @@map("comments")
}

model Label {
  id      String @id @default(cuid())
  name    String
  color   String
  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@index([boardId])
  @@map("labels")
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  key          String
  mimeType     String?  @map("mime_type")
  size         Int?
  cardId       String   @map("card_id")
  uploadedById String   @map("uploaded_by_id")
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([key, cardId])
  @@index([cardId])
  @@map("attachments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  message   String
  link      String? // deep link tới card/board liên quan
  isRead    Boolean          @default(false) @map("is_read")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  userId                 String         @id @map("user_id")
  emailFrequency         EmailFrequency @default(INSTANT) @map("email_frequency")
  commentsEnabled        Boolean        @default(true) @map("comments_enabled")
  dueDatesEnabled        Boolean        @default(true) @map("due_dates_enabled")
  removedFromCardEnabled Boolean        @default(true) @map("removed_from_card_enabled")
  attachmentsEnabled     Boolean        @default(true) @map("attachments_enabled")
  cardsMovedEnabled      Boolean        @default(true) @map("cards_moved_enabled")
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model BoardView {
  userId   String   @map("user_id")
  boardId  String   @map("board_id")
  viewedAt DateTime @default(now()) @map("viewed_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@id([userId, boardId])
  @@index([userId, viewedAt])
  @@map("board_views")
}

model BoardStar {
  userId    String   @map("user_id")
  boardId   String   @map("board_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@id([userId, boardId])
  @@index([userId])
  @@map("board_stars")
}

model BoardInvite {
  id          String    @id @default(cuid())
  boardId     String    @map("board_id")
  email       String
  role        Role      @default(MEMBER)
  tokenHash   String    @unique @map("token_hash")
  invitedById String    @map("invited_by_id")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation(fields: [invitedById], references: [id])

  @@index([boardId])
  @@index([email])
  @@map("board_invites")
}

model BoardInviteLink {
  id           String               @id @default(cuid())
  boardId      String               @unique @map("board_id")
  token        String               @unique
  role         Role                 @default(MEMBER)
  permission   InviteLinkPermission @default(OPEN)
  createdById  String               @map("created_by_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  board        Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation(fields: [createdById], references: [id])
  joinRequests BoardJoinRequest[]

  @@map("board_invite_links")
}

model BoardJoinRequest {
  id           String            @id @default(cuid())
  inviteLinkId String            @map("invite_link_id")
  userId       String            @map("user_id")
  status       JoinRequestStatus @default(PENDING)
  createdAt    DateTime          @default(now()) @map("created_at")
  decidedAt    DateTime?         @map("decided_at")
  inviteLink   BoardInviteLink   @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteLinkId, userId])
  @@map("board_join_requests")
}

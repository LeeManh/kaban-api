// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  CARD_ASSIGNED
  DUE_REMINDER
  COMMENT_MENTION
  BOARD_INVITATION
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshToken  RefreshToken[]
  ownedBoards   Board[]        @relation("BoardOwner")
  boardMembers  BoardMember[]
  comments      Comment[]
  attachments   Attachment[]
  assignedCards Card[]         @relation("CardAssignees")
  notifications Notification[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Board {
  id        String        @id @default(cuid())
  name      String
  ownerId   String        @map("owner_id")
  owner     User          @relation("BoardOwner", fields: [ownerId], references: [id])
  members   BoardMember[]
  lists     List[]
  labels    Label[]
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("boards")
}

model BoardMember {
  boardId String @map("board_id")
  userId  String @map("user_id")
  role    Role   @default(MEMBER)
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
  @@index([userId])
  @@map("board_members")
}

model List {
  id        String   @id @default(cuid())
  title     String
  order     Float
  boardId   String   @map("board_id")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([boardId, order])
  @@map("lists")
}

model Card {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  order       Float
  priority    CardPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  version     Int          @default(0)
  listId      String       @map("list_id")
  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels      Label[]
  comments    Comment[]
  checklists  Checklist[]
  attachments Attachment[]
  assignees   User[]       @relation("CardAssignees")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([listId, order])
  @@map("cards")
}

model Checklist {
  id        String          @id @default(cuid())
  title     String
  order     Float
  cardId    String          @map("card_id")
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([cardId, order])
  @@map("checklists")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  content     String
  isDone      Boolean   @default(false) @map("is_done")
  order       Float
  checklistId String    @map("checklist_id")
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, order])
  @@map("checklist_items")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  cardId    String   @map("card_id")
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cardId, createdAt])
  @@map("comments")
}

model Label {
  id      String @id @default(cuid())
  name    String
  color   String
  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@index([boardId])
  @@map("labels")
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  key          String   @unique
  mimeType     String?  @map("mime_type")
  size         Int?
  cardId       String   @map("card_id")
  uploadedById String   @map("uploaded_by_id")
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([cardId])
  @@map("attachments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id") 
  type      NotificationType
  message   String
  link      String? // deep link tới card/board liên quan
  isRead    Boolean          @default(false) @map("is_read")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
